# =====================================================
# CMMS HVAC PRO — Variables de entorno
# Copia este archivo como .env.local para desarrollo
# =====================================================

# URL base del backend API (sin slash final)
# Producción: configura esto en el dashboard de Vercel → Settings → Environment Variables
# Desarrollo: si usas proxy, deja vacío o usa la URL directa de tu backend
VITE_API_URL=https://tu-backend.vercel.app

# Solo para desarrollo local — activa el proxy de Vite hacia el backend
# Ejemplo: VITE_DEV_API_TARGET=http://localhost:3000
# Si configuras esto, el proxy reenvía /api/* → tu backend (sin problemas de CORS)
VITE_DEV_API_TARGET=
